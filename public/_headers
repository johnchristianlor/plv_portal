/student-exam.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Permissions-Policy: camera=(), microphone=(), display-capture=()

/student-exam-module.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

